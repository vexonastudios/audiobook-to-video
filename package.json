{
  "name": "audiobook-video-generator",
  "version": "1.0.0",
  "description": "Audiobook to Video by Bodee Books",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^1.4.1",
    "@fontsource/eb-garamond": "^5.1.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "electron": "^29.4.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.bodeebooks.videogenerator",
    "productName": "Audiobook to Video by Bodee Books",
    "asar": true,
    "files": [
      "**/*",
      "!node_modules/electron-builder/**"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "extraResources": []
  }
}
