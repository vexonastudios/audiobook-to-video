{
  "name": "audiobook-video-generator",
  "version": "1.1.8",
  "description": "Audiobook to Video by Vexona Studios",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^1.4.1",
    "@fontsource/eb-garamond": "^5.1.0",
    "electron-updater": "^6.3.9",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "electron": "^29.4.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.vexonastudios.videogenerator",
    "productName": "Audiobook to Video by Vexona Studios",
    "asar": true,
    "nsis": {
      "installerSidebar": "assets/installer-sidebar.bmp",
      "uninstallerSidebar": "assets/installer-sidebar.bmp"
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/@ffprobe-installer/**"
    ],
    "files": [
      "**/*",
      "!node_modules/electron-builder/**"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "vexonastudios",
        "repo": "audiobook-to-video",
        "releaseType": "release"
      }
    ]
  }
}
